SYSTEM_PROMPT = """Você é um assistente especializado em consultas de Notas Fiscais recebidas nos centros de distribuição.

Seu papel é responder perguntas sobre:
- Status de notas fiscais recebidas
- Pedidos de compra e seus materiais
- Situação de fornecedores
- NFs pendentes por centro de distribuição

Sempre que precisar de dados, use as ferramentas disponíveis para consultar o banco.
Responda de forma clara e objetiva, destacando o status da NF e qualquer pendência encontrada.
Responda sempre em português brasileiro."""


def executar_tool(nome: str, inputs: dict) -> str:
    if nome == "consultar_nf":
        return consultar_nf(inputs["nr_nfe"])
    elif nome == "consultar_pedido":
        return consultar_pedido(inputs["pedido"])
    elif nome == "consultar_fornecedor":
        return consultar_fornecedor(inputs["nome_ou_cnpj"])
    elif nome == "listar_pendentes":
        return listar_pendentes(inputs.get("depositante", ""))
    return json.dumps({"erro": "Ferramenta desconhecida."})


def perguntar(cliente: anthropic.Anthropic, historico: list, pergunta: str) -> str:
    historico.append({"role": "user", "content": pergunta})

    while True:
        resposta = cliente.messages.create(
            model="claude-haiku-4-5-20251001",
            max_tokens=1024,
            system=SYSTEM_PROMPT,
            tools=TOOLS,
            messages=historico
        )

        if resposta.stop_reason == "tool_use":
            # Adiciona a resposta do assistente ao histórico
            historico.append({"role": "assistant", "content": resposta.content})

            resultados = []
            for bloco in resposta.content:
                if bloco.type == "tool_use":
                    print(f"  [consultando: {bloco.name}({bloco.input})]")
                    resultado = executar_tool(bloco.name, bloco.input)
                    resultados.append({
                        "type": "tool_result",
                        "tool_use_id": bloco.id,
                        "content": resultado
                    })

            historico.append({"role": "user", "content": resultados})

        else:
            texto = next(
                (b.text for b in resposta.content if hasattr(b, "text")), ""
            )
            historico.append({"role": "assistant", "content": texto})
            return texto


def main():
    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print("Erro: variável ANTHROPIC_API_KEY não encontrada.")
        print("Execute: setx ANTHROPIC_API_KEY \"sua-chave-aqui\" e reabra o terminal.")
        return

    if not os.path.exists(DB_PATH):
        print(f"Erro: banco '{DB_PATH}' não encontrado na pasta atual.")
        print("Rode primeiro: python importar_nf_simples.py seu_arquivo.xlsx")
        return

    cliente = anthropic.Anthropic(api_key=api_key)
    historico = []

    print("=" * 55)
    print("  Agente de Notas Fiscais — digite 'sair' para encerrar")
    print("=" * 55)

    while True:
        pergunta = input("\nVocê: ").strip()
        if not pergunta:
            continue
        if pergunta.lower() in ("sair", "exit", "quit"):
            print("Encerrando agente.")
            break

        resposta = perguntar(cliente, historico, pergunta)
        print(f"\nAgente: {resposta}")


if __name__ == "__main__":
    main()
