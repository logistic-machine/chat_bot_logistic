import os
import sqlite3
import json
import anthropic

DB_PATH = "Nome do seu banco de dados"

def consultar_nf(nr_nfe: str) -> str:
    """Busca todos os itens de uma NF pelo número."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    rows = conn.execute("""
        SELECT nr_nfe, nome_fornecedor, cnpj_fornecedor, pedido_compras,
               desc_material, cod_material, valor_total, qtd_recebida,
               data_documento, data_recebimento, ultima_etapa, depositante
        FROM notas_fiscais
        WHERE nr_nfe = ?
    """, (nr_nfe,)).fetchall()
    conn.close()
    if not rows:
        return json.dumps({"erro": f"NF {nr_nfe} não encontrada."})
    return json.dumps([dict(r) for r in rows], ensure_ascii=False, default=str)


def consultar_pedido(pedido: str) -> str:
    """Busca NFs pelo número do pedido de compras."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    rows = conn.execute("""
        SELECT nr_nfe, nome_fornecedor, pedido_compras, desc_material,
               valor_total, qtd_recebida, data_recebimento,
               ultima_etapa, depositante
        FROM notas_fiscais
        WHERE pedido_compras = ?
    """, (pedido,)).fetchall()
    conn.close()
    if not rows:
        return json.dumps({"erro": f"Pedido {pedido} não encontrado."})
    return json.dumps([dict(r) for r in rows], ensure_ascii=False, default=str)


def consultar_fornecedor(nome_ou_cnpj: str) -> str:
    """Busca NFs pelo nome ou CNPJ do fornecedor."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    termo = f"%{nome_ou_cnpj}%"
    rows = conn.execute("""
        SELECT nr_nfe, nome_fornecedor, cnpj_fornecedor, pedido_compras,
               desc_material, valor_total, data_recebimento,
               ultima_etapa, depositante
        FROM notas_fiscais
        WHERE nome_fornecedor LIKE ? OR cnpj_fornecedor LIKE ?
        LIMIT 50
    """, (termo, termo)).fetchall()
    conn.close()
    if not rows:
        return json.dumps({"erro": f"Fornecedor '{nome_ou_cnpj}' não encontrado."})
    return json.dumps([dict(r) for r in rows], ensure_ascii=False, default=str)


def listar_pendentes(depositante: str = "") -> str:
    """Lista NFs que ainda não concluíram o processo, filtrando por CD se informado."""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    etapas_pendentes = (
        "Nota fiscal não concluida",
        "Simular fatura e NF-e",
        "Lançar fatura e NF-e",
        "Atribuir itens do pedido",
        "Verificar autorização após entrada NF-e",
        "Verificar autorização após entrada DANFE",
        "Registrar entrada de mercadorias",
    )
    placeholders = ",".join("?" * len(etapas_pendentes))
    params = list(etapas_pendentes)
    filtro = ""
    if depositante:
        filtro = f"AND depositante LIKE ?"
        params.append(f"%{depositante}%")
    rows = conn.execute(f"""
        SELECT nr_nfe, nome_fornecedor, pedido_compras, desc_material,
               valor_total, data_recebimento, ultima_etapa, depositante
        FROM notas_fiscais
        WHERE ultima_etapa IN ({placeholders}) {filtro}
        ORDER BY data_recebimento
        LIMIT 100
    """, params).fetchall()
    conn.close()
    if not rows:
        return json.dumps({"mensagem": "Nenhuma NF pendente encontrada."})
    return json.dumps([dict(r) for r in rows], ensure_ascii=False, default=str)

